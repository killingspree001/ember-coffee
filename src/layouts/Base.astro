---
import "../styles/global.scss";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ember Coffee Roasters — small-batch coffee, roasted by fire",
  description = "A small-batch coffee roaster. Seasonal single origins and blends, roasted by fire in small drums and shipped within days.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..700&family=DM+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <script>
      import "../scripts/motion.ts";
    </script>
  </body>
</html>
