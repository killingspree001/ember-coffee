---
---

<section class="join section" id="shop">
  <div class="container">
    <div class="join__panel" data-reveal>
      <p class="eyebrow join__eyebrow">The subscription</p>
      <h2 class="join__title" data-split>Fresh beans, every fortnight</h2>
      <p class="join__lead">
        Pick a roast, pick a rhythm. We grind to order and post it the morning
        it&apos;s roasted. Skip or cancel any time.
      </p>

      <form class="join__form" id="join-form">
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          aria-label="Email address"
        />
        <button type="submit" class="btn join__btn">Join the club</button>
      </form>
      <p class="join__note" id="join-note" hidden>
        You&apos;re on the list — check your inbox to confirm.
      </p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("join-form") as HTMLFormElement | null;
  const note = document.getElementById("join-note");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (note) note.hidden = false;
    form.reset();
  });
</script>

<style lang="scss">
  .join {
    background: var(--void);
  }

  .join__panel {
    position: relative;
    overflow: hidden;
    background: var(--amber);
    color: var(--void);
    border-radius: 2rem;
    padding: clamp(2.5rem, 7vw, 5rem);
    text-align: center;
    background-image: radial-gradient(
        circle at 82% 16%,
        rgba(255, 255, 255, 0.18),
        transparent 45%
      ),
      radial-gradient(circle at 8% 92%, rgba(16, 13, 10, 0.16), transparent 40%);
  }

  .join__eyebrow {
    color: rgba(16, 13, 10, 0.7);
  }
  .join__eyebrow::before {
    background: rgba(16, 13, 10, 0.7);
  }

  .join__title {
    font-size: clamp(2.2rem, 5.5vw, 4rem);
    margin: 0.8rem 0 1.1rem;
  }

  .join__lead {
    max-width: 36rem;
    margin: 0 auto;
    color: rgba(16, 13, 10, 0.78);
  }

  .join__form {
    margin: 2.2rem auto 0;
    max-width: 31rem;
    display: flex;
    gap: 0.5rem;
    background: var(--paper);
    padding: 0.4rem;
    border-radius: 100px;
  }

  .join__form input {
    flex: 1;
    min-width: 0;
    border: none;
    background: transparent;
    padding: 0.75rem 1.1rem;
    font: inherit;
    color: var(--void);

    &:focus {
      outline: none;
    }
  }

  .join__btn {
    background: var(--void);
    color: var(--paper);
    white-space: nowrap;

    &:hover {
      background: var(--coal);
      box-shadow: none;
      transform: none;
    }
  }

  .join__note {
    margin-top: 1rem;
    font-weight: 700;
    color: var(--void);
  }

  @media (max-width: 520px) {
    .join__form {
      flex-direction: column;
      border-radius: 1.4rem;
    }
    .join__btn {
      justify-content: center;
    }
  }
</style>
