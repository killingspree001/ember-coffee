---
---

<section class="hero">
  <div class="hero__media" data-hero-media>
    <img
      data-parallax="20"
      src="/images/hero.jpg"
      alt="A slow pour of coffee in low light"
      fetchpriority="high"
    />
    <div class="hero__scrim"></div>
    <div class="hero__cover" data-hero-cover></div>
  </div>

  <div class="container hero__content">
    <p class="eyebrow">Small batch · roasted by fire</p>
    <h1 class="hero__title display" data-split data-hero>
      Coffee worth<br />slowing down for
    </h1>
    <p class="hero__lead" data-reveal>
      A small roastery working in cast-iron drums. Seasonal single origins,
      roasted dark or bright, shipped within days of the cooling tray.
    </p>
    <div class="hero__actions" data-reveal>
      <a href="#coffees" class="btn">Explore the roasts</a>
      <a href="#story" class="btn btn--ghost">Our story</a>
    </div>
  </div>

  <div class="container hero__foot">
    <span data-reveal>Portland, OR</span>
    <span data-reveal>Est. 2019</span>
    <span data-reveal>Roasted to order</span>
  </div>
</section>

<style lang="scss">
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }

  .hero__media {
    position: absolute;
    inset: -10% 0;
    z-index: 0;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(16, 13, 10, 0.92) 0%,
      rgba(16, 13, 10, 0.45) 42%,
      rgba(16, 13, 10, 0.55) 100%
    );
  }

  .hero__cover {
    position: absolute;
    inset: 0;
    background: var(--void);
    z-index: 2;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    padding-bottom: clamp(2rem, 4vw, 3rem);
    padding-top: 8rem;
  }

  .hero__title {
    margin-top: 1.3rem;
    color: var(--cream);
  }

  .hero__lead {
    margin-top: 1.8rem;
    max-width: 36rem;
    font-size: 1.2rem;
    color: rgba(241, 231, 214, 0.78);
  }

  .hero__actions {
    margin-top: 2.3rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  .hero__foot {
    position: relative;
    z-index: 3;
    display: flex;
    gap: clamp(1.5rem, 5vw, 4rem);
    padding-bottom: clamp(2rem, 5vw, 3.5rem);
    padding-top: clamp(2.5rem, 6vw, 4rem);
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);

    span {
      position: relative;
      padding-left: 1.1rem;
    }
    span::before {
      content: "";
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--amber);
    }
  }

  @media (max-width: 620px) {
    .hero__foot {
      flex-wrap: wrap;
      gap: 0.75rem 1.5rem;
    }
  }
</style>
