---

<section class="quote">
  <div class="quote__media">
    <img data-parallax="22" src="/images/atmosphere.jpg" loading="lazy" alt="A quiet corner of the roastery" />
    <div class="quote__scrim"></div>
  </div>

  <div class="container quote__inner">
    <blockquote class="quote__text" data-split>
      Good coffee isn&apos;t complicated. It&apos;s just someone caring about
      every small thing, all the way down.
    </blockquote>
    <cite class="quote__cite" data-reveal>— Mara Okonkwo, founder &amp; head roaster</cite>
  </div>
</section>

<style lang="scss">
  .quote {
    position: relative;
    color: var(--cream);
    padding-block: clamp(7rem, 16vw, 13rem);
    overflow: hidden;
  }

  .quote__media {
    position: absolute;
    inset: -12% 0;
    z-index: 0;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .quote__scrim {
    position: absolute;
    inset: 0;
    background: rgba(16, 13, 10, 0.72);
  }

  .quote__inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 60rem;
  }

  .quote__text {
    font-family: "Bricolage Grotesque", sans-serif;
    font-weight: 500;
    font-size: clamp(1.9rem, 4.6vw, 3.4rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .quote__cite {
    display: block;
    margin-top: 2rem;
    font-style: normal;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
</style>
