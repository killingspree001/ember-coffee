---
const steps = [
  { n: "01", title: "Weigh & grind", body: "Eighteen grams, ground medium-coarse, just before you brew." },
  { n: "02", title: "Bloom", body: "A splash off the boil. Wait forty seconds for the gas to escape." },
  { n: "03", title: "Pour slow", body: "Steady spirals to three hundred grams. No rush — enjoy this part." },
  { n: "04", title: "Sit with it", body: "Let it cool a minute. The flavours open up as it does." },
];
---

<section class="ritual section" id="ritual">
  <div class="container ritual__grid">
    <div class="ritual__media reveal" data-clip>
      <img src="/images/brew.jpg" loading="lazy" alt="A slow pour-over brew" />
      <span class="reveal__cover"></span>
    </div>

    <div class="ritual__text">
      <p class="eyebrow" data-reveal>The ritual</p>
      <h2 class="ritual__title" data-split>Four steps to a better cup</h2>
      <ol class="ritual__steps" data-stagger>
        {
          steps.map((s) => (
            <li class="step">
              <span class="step__num">{s.n}</span>
              <div>
                <h3 class="step__title">{s.title}</h3>
                <p class="step__body">{s.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style lang="scss">
  .ritual {
    background: var(--coal);
  }

  .ritual__grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  .ritual__media {
    position: relative;
    border-radius: 1.5rem;
    overflow: hidden;
    aspect-ratio: 3 / 4;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .reveal__cover {
    position: absolute;
    inset: 0;
    background: var(--void);
    z-index: 2;
  }

  .ritual__title {
    font-size: clamp(2.1rem, 4.8vw, 3.6rem);
    margin: 0.9rem 0 2.2rem;
    max-width: 12ch;
  }

  .ritual__steps {
    list-style: none;
    display: grid;
    gap: 1.6rem;
  }

  .step {
    display: flex;
    gap: 1.3rem;
    padding-bottom: 1.6rem;
    border-bottom: 1px solid var(--line);

    &:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }
  }

  .step__num {
    font-family: "Bricolage Grotesque", sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--amber);
    min-width: 2.5rem;
  }

  .step__title {
    font-size: 1.35rem;
  }

  .step__body {
    margin-top: 0.35rem;
    color: var(--muted);
    max-width: 30rem;
  }

  @media (max-width: 820px) {
    .ritual__grid {
      grid-template-columns: 1fr;
    }
    .ritual__media {
      aspect-ratio: 16 / 11;
    }
  }
</style>
